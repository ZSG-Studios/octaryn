include("${CMAKE_CURRENT_LIST_DIR}/../../Shared/TargetArchitecture.cmake")

set(CMAKE_SYSTEM_NAME Linux)
octaryn_arch_select(OCTARYN_LINUX_SYSTEM_PROCESSOR x86_64 aarch64)
set(CMAKE_SYSTEM_PROCESSOR "${OCTARYN_LINUX_SYSTEM_PROCESSOR}")
set(CMAKE_C_COMPILER clang)
set(CMAKE_CXX_COMPILER clang++)

if(OCTARYN_TARGET_ARCH STREQUAL "arm64")
    set(OCTARYN_LINUX_ARM64_SYSROOT "$ENV{OCTARYN_LINUX_ARM64_SYSROOT}" CACHE PATH "Linux ARM64 sysroot for Clang cross-builds.")
    if(NOT OCTARYN_LINUX_ARM64_SYSROOT)
        set(OCTARYN_LINUX_ARM64_SYSROOT "${CMAKE_CURRENT_LIST_DIR}/../../../build/dependencies/sysroots/linux-arm64/root" CACHE PATH "Linux ARM64 sysroot for Clang cross-builds." FORCE)
    endif()
    if(NOT OCTARYN_LINUX_ARM64_SYSROOT OR NOT EXISTS "${OCTARYN_LINUX_ARM64_SYSROOT}")
        message(FATAL_ERROR "Linux arm64 cross-build requires a target sysroot. Run tools/build/linux_arm64_sysroot.sh setup or set OCTARYN_LINUX_ARM64_SYSROOT.")
    endif()
    set(CMAKE_C_COMPILER_TARGET aarch64-linux-gnu)
    set(CMAKE_CXX_COMPILER_TARGET aarch64-linux-gnu)
    find_program(OCTARYN_LINUX_LLVM_AR llvm-ar REQUIRED)
    find_program(OCTARYN_LINUX_LLVM_RANLIB llvm-ranlib REQUIRED)
    set(CMAKE_AR "${OCTARYN_LINUX_LLVM_AR}" CACHE FILEPATH "Linux ARM64 LLVM archiver" FORCE)
    set(CMAKE_RANLIB "${OCTARYN_LINUX_LLVM_RANLIB}" CACHE FILEPATH "Linux ARM64 LLVM ranlib" FORCE)
    set(CMAKE_C_COMPILER_AR "${OCTARYN_LINUX_LLVM_AR}" CACHE FILEPATH "Linux ARM64 C compiler archiver" FORCE)
    set(CMAKE_CXX_COMPILER_AR "${OCTARYN_LINUX_LLVM_AR}" CACHE FILEPATH "Linux ARM64 C++ compiler archiver" FORCE)
    set(CMAKE_C_COMPILER_RANLIB "${OCTARYN_LINUX_LLVM_RANLIB}" CACHE FILEPATH "Linux ARM64 C compiler ranlib" FORCE)
    set(CMAKE_CXX_COMPILER_RANLIB "${OCTARYN_LINUX_LLVM_RANLIB}" CACHE FILEPATH "Linux ARM64 C++ compiler ranlib" FORCE)
    set(CMAKE_EXE_LINKER_FLAGS_INIT "-fuse-ld=lld")
    set(CMAKE_SHARED_LINKER_FLAGS_INIT "-fuse-ld=lld")
    set(CMAKE_MODULE_LINKER_FLAGS_INIT "-fuse-ld=lld")
    set(CMAKE_SYSROOT "${OCTARYN_LINUX_ARM64_SYSROOT}" CACHE PATH "Linux ARM64 sysroot" FORCE)
    set(ENV{PKG_CONFIG_SYSROOT_DIR} "${OCTARYN_LINUX_ARM64_SYSROOT}")
    set(ENV{PKG_CONFIG_LIBDIR} "${OCTARYN_LINUX_ARM64_SYSROOT}/usr/lib/pkgconfig:${OCTARYN_LINUX_ARM64_SYSROOT}/usr/share/pkgconfig")
    set(CMAKE_FIND_ROOT_PATH "${OCTARYN_LINUX_ARM64_SYSROOT}")
    set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
    set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
    set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
    set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
endif()
