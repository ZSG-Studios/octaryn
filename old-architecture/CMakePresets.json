{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build/old-architecture/shared/workspace/${presetName}/cmake",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_STANDARD": "17",
        "CMAKE_C_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "OCTARYN_BUILD_PRESET_NAME": "${presetName}",
        "OCTARYN_WORKSPACE_ROOT_DIR": "${sourceDir}/.."
      }
    },
    {
      "name": "host-linux",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_LINKER_TYPE": "LLD"
      }
    },
    {
      "name": "host-windows",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "CMAKE_CXX_EXTENSIONS": "ON"
      }
    },
    {
      "name": "target-windows-x64",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "toolchainFile": "${sourceDir}/cmake/toolchains/windows-x64.cmake",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "x86_64-w64-mingw32-gcc",
        "CMAKE_CXX_COMPILER": "x86_64-w64-mingw32-g++",
        "CMAKE_RC_COMPILER": "x86_64-w64-mingw32-windres",
        "CMAKE_CROSSCOMPILING": "ON",
        "CMAKE_FIND_ROOT_PATH": "/usr/x86_64-w64-mingw32"
      }
    },
    {
      "name": "preset-linux-debug",
      "hidden": true,
      "inherits": ["base", "host-linux", "host-windows"],
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "ON",
        "CMAKE_BUILD_TYPE": "Debug",
        "OCTARYN_DEPENDENCY_BUCKET_NAME": "linux-debug-shared",
        "OCTARYN_ENABLE_ASSET_PIPELINE": "ON",
        "OCTARYN_ENABLE_ANIMATION": "ON",
        "OCTARYN_ENABLE_AUDIO": "ON",
        "OCTARYN_ENABLE_CRASH_DIAGNOSTICS": "ON",
        "OCTARYN_ENABLE_NETWORKING": "OFF",
        "OCTARYN_ENABLE_PHYSICS": "ON",
        "OCTARYN_ENABLE_PROFILING": "OFF",
        "OCTARYN_ENABLE_RENDERING": "ON",
        "OCTARYN_ENABLE_UI_TEXT": "OFF",
        "OCTARYN_PREFER_SHARED_DEPS": "ON"
      }
    },
    {
      "name": "preset-linux-profile",
      "hidden": true,
      "inherits": ["base", "host-linux", "host-windows"],
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "ON",
        "CMAKE_BUILD_TYPE": "Debug",
        "OCTARYN_DEPENDENCY_BUCKET_NAME": "linux-debug-shared",
        "OCTARYN_ENABLE_ASSET_PIPELINE": "ON",
        "OCTARYN_ENABLE_ANIMATION": "ON",
        "OCTARYN_ENABLE_AUDIO": "ON",
        "OCTARYN_ENABLE_CRASH_DIAGNOSTICS": "ON",
        "OCTARYN_ENABLE_NETWORKING": "OFF",
        "OCTARYN_ENABLE_PHYSICS": "ON",
        "OCTARYN_ENABLE_PROFILING": "ON",
        "OCTARYN_ENABLE_RENDERING": "ON",
        "OCTARYN_ENABLE_UI_TEXT": "OFF",
        "OCTARYN_PREFER_SHARED_DEPS": "ON"
      }
    },
    {
      "name": "preset-linux-release",
      "hidden": true,
      "inherits": ["base", "host-linux", "host-windows"],
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "OFF",
        "CMAKE_BUILD_TYPE": "Release",
        "OCTARYN_DEPENDENCY_BUCKET_NAME": "linux-release-static",
        "OCTARYN_ENABLE_ASSET_PIPELINE": "ON",
        "OCTARYN_ENABLE_ANIMATION": "ON",
        "OCTARYN_ENABLE_AUDIO": "ON",
        "OCTARYN_ENABLE_CRASH_DIAGNOSTICS": "ON",
        "OCTARYN_ENABLE_NETWORKING": "OFF",
        "OCTARYN_ENABLE_PHYSICS": "ON",
        "OCTARYN_ENABLE_LTO": "ON",
        "OCTARYN_ENABLE_PROFILING": "OFF",
        "OCTARYN_ENABLE_RENDERING": "ON",
        "OCTARYN_ENABLE_UI_TEXT": "OFF",
        "OCTARYN_PREFER_SHARED_DEPS": "OFF"
      }
    },
    {
      "name": "preset-windows-debug",
      "hidden": true,
      "inherits": ["base", "target-windows-x64"],
      "binaryDir": "${sourceDir}/../build/old-architecture/shared/workspace/${presetName}/cmake",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "OFF",
        "CMAKE_BUILD_TYPE": "Debug",
        "OCTARYN_DEPENDENCY_BUCKET_NAME": "windows-debug",
        "OCTARYN_ENABLE_ASSET_PIPELINE": "OFF",
        "OCTARYN_ENABLE_RUNTIME_ASSET_GENERATION": "OFF",
        "OCTARYN_ENABLE_ANIMATION": "ON",
        "OCTARYN_ENABLE_AUDIO": "ON",
        "OCTARYN_ENABLE_CRASH_DIAGNOSTICS": "ON",
        "OCTARYN_ENABLE_MANAGED_DOTNET": "OFF",
        "OCTARYN_ENABLE_NETWORKING": "OFF",
        "OCTARYN_ENABLE_PHYSICS": "ON",
        "OCTARYN_ENABLE_PROFILING": "OFF",
        "OCTARYN_ENABLE_RENDERING": "ON",
        "OCTARYN_ENABLE_UI_TEXT": "OFF",
        "OCTARYN_PREFER_SHARED_DEPS": "OFF"
      }
    },
    {
      "name": "preset-windows-release",
      "hidden": true,
      "inherits": ["base", "target-windows-x64"],
      "binaryDir": "${sourceDir}/../build/old-architecture/shared/workspace/${presetName}/cmake",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "OFF",
        "CMAKE_BUILD_TYPE": "Release",
        "OCTARYN_DEPENDENCY_BUCKET_NAME": "windows-release",
        "OCTARYN_ENABLE_ASSET_PIPELINE": "OFF",
        "OCTARYN_ENABLE_RUNTIME_ASSET_GENERATION": "OFF",
        "OCTARYN_ENABLE_ANIMATION": "ON",
        "OCTARYN_ENABLE_AUDIO": "ON",
        "OCTARYN_ENABLE_CRASH_DIAGNOSTICS": "ON",
        "OCTARYN_ENABLE_LTO": "OFF",
        "OCTARYN_ENABLE_MANAGED_DOTNET": "OFF",
        "OCTARYN_ENABLE_NETWORKING": "OFF",
        "OCTARYN_ENABLE_PHYSICS": "ON",
        "OCTARYN_ENABLE_PROFILING": "OFF",
        "OCTARYN_ENABLE_RENDERING": "ON",
        "OCTARYN_ENABLE_UI_TEXT": "OFF",
        "OCTARYN_PREFER_SHARED_DEPS": "OFF"
      }
    },
    {
      "name": "linux-debug",
      "inherits": ["preset-linux-debug"]
    },
    {
      "name": "linux-profile",
      "inherits": ["preset-linux-profile"]
    },
    {
      "name": "linux-release",
      "inherits": ["preset-linux-release"]
    },
    {
      "name": "windows-debug",
      "inherits": ["preset-windows-debug"]
    },
    {
      "name": "windows-release",
      "inherits": ["preset-windows-release"]
    }
  ],
  "buildPresets": [
    {"name": "linux-debug", "configurePreset": "linux-debug", "targets": ["all"]},
    {"name": "linux-profile", "configurePreset": "linux-profile", "targets": ["all"]},
    {"name": "linux-release", "configurePreset": "linux-release", "targets": ["all"]},
    {"name": "windows-debug", "configurePreset": "windows-debug", "targets": ["octaryn_engine_runtime"]},
    {"name": "windows-release", "configurePreset": "windows-release", "targets": ["octaryn_engine_runtime"]}
  ]
}
